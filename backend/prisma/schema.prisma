generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  phone        String?   @unique
  email        String?   @unique
  passwordHash String    @map("password_hash")
  nickname     String    @default("")
  avatar       String?   @default("/default-avatar.png")
  bio          String?   @default("")
  level        Int       @default(1)
  role         String    @default("user") // user, creator, admin
  status       String    @default("active") // active, banned, deactivated
  inviteCode   String    @unique @map("invite_code")
  invitedBy    Int?      @map("invited_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  balance     UserBalance?
  preferences UserPreference?
  apiConfigs  UserApiConfig[]
  scripts     Script[]
  sessions    GameSession[]
  saves       Save[]
  transactions TransactionLog[]
  payments    PaymentOrder[]
  posts       Post[]
  comments    Comment[]
  sentFollows Follow[]      @relation("FollowerFollows")
  recvFollows Follow[]      @relation("FollowingFollows")
  favorites   Favorite[]
  notifications Notification[]
  invitations Invitation[] @relation("InviterInvitations")
  invitation  Invitation?  @relation("InviteeInvitation")
  achievements UserAchievement[]
  scriptTemplates ScriptTemplate[]
  promotionRewards PromotionReward[]
  creatorLevel CreatorLevel?

  @@map("users")
}

model UserBalance {
  userId           Int  @id @map("user_id")
  permanentBalance Int  @default(0) @map("permanent_balance")
  tempBalance      Int  @default(0) @map("temp_balance")
  tempExpireAt     DateTime? @map("temp_expire_at")
  totalIncome      Int  @default(0) @map("total_income")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_balances")
}

model UserPreference {
  userId         Int    @id @map("user_id")
  theme          String @default("light")
  modelPreference String? @map("model_preference")
  useCustomApi   Boolean @default(true) @map("use_custom_api")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Script {
  id             Int      @id @default(autoincrement())
  authorId       Int      @map("author_id")
  title          String
  cover          String?
  desc           String?  @default("")
  category       String   @default("adventure")
  worldSetting   String?  @default("") @map("world_setting")
  styleId        Int?     @map("style_id")
  playCount      Int      @default(0) @map("play_count")
  favCount       Int      @default(0) @map("fav_count")
  status         String   @default("draft") // draft,reviewing,published,rejected,archived
  rejectionReason String? @map("rejection_reason")
  createdAt      DateTime @default(now()) @map("created_at")

  // 剧本自产系统扩展字段
  narrativeRules String?  @default("") @map("narrative_rules") // AI润色后的叙事规则（贯穿游玩全程）
  charConfig     String?  @default("{}") @map("char_config") // 角色创建配置JSON（家世/性格/特质等选项）
  tags           String?  @default("[]") @map("tags") // 剧本标签JSON
  themeColor     String?  @default("") @map("theme_color") // 主题配色
  engineType     String?  @default("standard") @map("engine_type") // 生成引擎类型
  openingText    String?  @default("") @map("opening_text") // 开场白文本（独立于节点）
  isAiGenerated  Boolean  @default(false) @map("is_ai_generated") // 是否AI生成
  logicConfig    String?  @default("{}") @map("logic_config") // 剧本逻辑配置JSON（事件链/结局触发器/故事章节等）

  author      User          @relation(fields: [authorId], references: [id])
  npcs        ScriptNpc[]
  attributes  ScriptAttribute[]
  nodes       ScriptNode[]
  sessions    GameSession[]
  comments    Comment[]
  favorites   Favorite[]
  inGameApps  InGameApp[]
  tagRelations ScriptTagRelation[]

  @@map("scripts")
}

model StyleTemplate {
  id       Int    @id @default(autoincrement())
  name     String
  icon     String @default("✨")
  preview  String @default("")
  prompt   String @default("")
  useCount Int    @default(0) @map("use_count")

  @@map("style_templates")
}

model ScriptNpc {
  id       Int    @id @default(autoincrement())
  scriptId Int    @map("script_id")
  name     String
  personality String @default("")
  avatar   String?
  sortOrder Int   @default(0) @map("sort_order")

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@map("script_npcs")
}

model ScriptAttribute {
  id       Int    @id @default(autoincrement())
  scriptId Int    @map("script_id")
  name     String
  type     String @default("number") // number, enum, boolean
  minVal   Float? @map("min_val")
  maxVal   Float? @map("max_val")
  defaultVal String? @map("default_val")
  thresholdRules String? @map("threshold_rules") // JSON string stored as Text for SQLite

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@map("script_attributes")
}

model ScriptNode {
  id        Int    @id @default(autoincrement())
  scriptId  Int    @map("script_id")
  type      String @default("scene") // scene, choice, condition, preset
  content   String @default("")
  choices   String? // JSON string stored as Text for SQLite
  condition String? // JSON string stored as Text for SQLite
  posX      Float? @map("pos_x")
  posY      Float? @map("pos_y")
  parentId  Int?   @map("parent_id")

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@map("script_nodes")
}

model GameSession {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  scriptId    Int      @map("script_id")
  gameState   String   @default("{}") @map("game_state") // JSON string stored as Text for SQLite
  totalTokens Int      @default(0) @map("total_tokens")
  totalCost   Int      @default(0) @map("total_cost")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  script  Script   @relation(fields: [scriptId], references: [id])
  saves   Save[]

  @@map("game_sessions")
}

model Save {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  sessionId   Int      @map("session_id")
  gameState   String   @default("{}") @map("game_state") // JSON string stored as Text for SQLite
  description String   @default("")
  isAuto      Boolean  @default(false) @map("is_auto")
  createdAt   DateTime @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id])
  session GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("saves")
}

model TransactionLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  type        String   // spend, income, recharge, withdraw, redeem
  amount      Int
  currency    String   @default("uu") // uu, rmb
  description String   @default("")
  relatedType String?  @map("related_type") // ai_call, payment, creator_income
  relatedId   Int?     @map("related_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("transaction_logs")
}

model PaymentOrder {
  id            Int      @id @default(autoincrement())
  orderNo       String   @unique @map("order_no")
  userId        Int      @map("user_id")
  amount        Float    @map("amount")
  uuAmount      Int      @map("uu_amount")
  paymentMethod String   @map("payment_method") // alipay, wechat
  tradeNo       String?  @map("trade_no")
  status        String   @default("pending") // pending, success, failed, expired
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("payment_orders")
}

model UserApiConfig {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  provider     String
  baseUrl      String   @map("base_url")
  encryptedKey String   @map("encrypted_key")
  iv           String?
  model        String   @default("")
  status       String   @default("unverified") // unverified, verified
  priority     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_api_configs")
}

model RedemptionCode {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  uuAmount    Int       @map("uu_amount")
  maxUses     Int       @default(1) @map("max_uses")
  currentUses Int       @default(0) @map("current_uses")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("redemption_codes")
}

model AiModel {
  id           Int    @id @default(autoincrement())
  name         String @unique
  displayName  String @map("display_name")
  rate         Float  @default(1.0)
  backendModel String @map("backend_model")
  multimodal   Boolean @default(false)
  maxTokens    Int    @default(4096) @map("max_tokens")
  isActive     Boolean @default(true) @map("is_active")

  @@map("ai_models")
}

model Post {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  content      String   @default("")
  images       String   @default("[]") // JSON string stored as Text for SQLite
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]

  @@map("posts")
}

model Comment {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  targetType String   @map("target_type") // script, post, app
  targetId   Int      @map("target_id")
  content    String   @default("")
  rating     Int?
  createdAt  DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  script Script? @relation(fields: [targetId], references: [id])
  post   Post?   @relation(fields: [targetId], references: [id])

  @@map("comments")
}

model Follow {
  id         Int      @id @default(autoincrement())
  followerId Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt  DateTime @default(now()) @map("created_at")

  follower User @relation("FollowerFollows", fields: [followerId], references: [id])
  following User @relation("FollowingFollows", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@map("follows")
}

model Favorite {
  userId     Int      @map("user_id")
  targetType String   @map("target_type") // script, post, app, character
  targetId   Int      @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  script Script? @relation(fields: [targetId], references: [id])

  @@id([userId, targetType, targetId])
  @@map("favorites")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @default("")
  title     String   @default("")
  content   String   @default("")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @default("")
  type      String   @default("normal") // normal, urgent
  createdAt DateTime @default(now()) @map("created_at")

  @@map("announcements")
}

model Invitation {
  id                    Int      @id @default(autoincrement())
  inviterId             Int      @map("inviter_id")
  inviteeId             Int      @unique @map("invitee_id")
  code                  String
  inviterRewardGranted  Boolean  @default(false) @map("inviter_reward_granted")
  inviteeRewardGranted  Boolean  @default(false) @map("invitee_reward_granted")
  createdAt             DateTime @default(now()) @map("created_at")

  inviter User @relation("InviterInvitations", fields: [inviterId], references: [id])
  invitee User @relation("InviteeInvitation", fields: [inviteeId], references: [id])

  @@map("invitations")
}

model Achievement {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String   @default("")
  icon        String   @default("🏆")
  category    String   @default("general") // general, creator, player, social
  condition   String   @default("") // JSON: { type, threshold }
  reward      Int      @default(0) // UU币奖励
  createdAt   DateTime @default(now()) @map("created_at")

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  achievementId  Int      @map("achievement_id")
  unlockedAt     DateTime @default(now()) @map("unlocked_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement  Achievement  @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model ScriptTemplate {
  id           Int      @id @default(autoincrement())
  name         String
  category     String   @default("adventure") // adventure, romance, mystery, horror, scifi, fantasy, school, wuxia, cultivation, idol, abo, infinite
  description  String   @default("")
  coverEmoji   String   @default("📖")
  worldSetting String   @default("") @map("world_setting")
  stylePrompt  String   @default("") @map("style_prompt")
  npcTemplate  String   @default("[]") @map("npc_template") // JSON: [{name, personality}]
  attrTemplate String   @default("[]") @map("attr_template") // JSON: [{name, type, defaultVal, minVal, maxVal}]
  nodeTemplate String   @default("[]") @map("node_template") // JSON: [{type, content, choices}]
  charConfig   String   @default("{}") @map("char_config") // JSON: 角色创建配置（家世/性格/特质等选项）
  useCount     Int      @default(0) @map("use_count")
  rating       Float    @default(0)
  ratingCount  Int      @default(0) @map("rating_count")
  authorId     Int?     @map("author_id") // null = 官方模板
  isOfficial   Boolean  @default(false) @map("is_official")
  tags         String   @default("[]") // JSON: ["高自由","全性向","养成"]
  createdAt    DateTime @default(now()) @map("created_at")

  author User? @relation(fields: [authorId], references: [id])

  @@map("script_templates")
}

// ========================
// UU平台对标扩展模型
// ========================

/// 推广奖励 - 用户在社交平台分享获得奖励
model PromotionReward {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  platform     String   // douyin, xiaohongshu, bilibili, weibo
  link         String   // 分享链接
  likesCount   Int      @default(0) @map("likes_count") // 点赞数
  rewardTier   String   @default("pending") // pending, tier1(10赞), tier2(100赞), tier3(1000赞)
  rewardAmount Int      @default(0) @map("reward_amount") // 奖励UU币数量
  status       String   @default("pending") // pending, approved, rejected
  reviewNote   String?  @map("review_note") // 审核备注
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("promotion_rewards")
}

/// 内置游戏APP - 剧本内的自定义软件（如校园助手、直播小助手等）
model InGameApp {
  id           Int      @id @default(autoincrement())
  scriptId     Int      @map("script_id")
  name         String   // APP名称
  icon         String   @default("📱") // APP图标emoji
  description  String   @default("")
  appType      String   @default("utility") // utility, social, shop, ranking, quest, custom
  config       String   @default("{}") // JSON: APP配置（功能模块、数据源等）
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@map("in_game_apps")
}

/// 作品标签 - 用于分类和搜索
model ScriptTag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  category  String   @default("general") // general, genre, theme, setting
  useCount  Int      @default(0) @map("use_count")
  createdAt DateTime @default(now()) @map("created_at")
  scripts   ScriptTagRelation[]

  @@map("script_tags")
}

/// 剧本与标签关联
model ScriptTagRelation {
  scriptId  Int @map("script_id")
  tagId     Int @map("tag_id")

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  tag    ScriptTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([scriptId, tagId])
  @@map("script_tag_relations")
}

/// 排行榜快照 - 定时统计排行数据
model RankingSnapshot {
  id           Int      @id @default(autoincrement())
  period       String   // daily, weekly, monthly, new, author
  scriptId     Int?     @map("script_id")
  authorId     Int?     @map("author_id")
  rank         Int
  playCount    Int      @default(0) @map("play_count")
  score        Float    @default(0) // 综合评分
  snapshotDate DateTime @default(now()) @map("snapshot_date")

  @@map("ranking_snapshots")
}

/// 创作者等级 - 对标UU的创作者分成系统
model CreatorLevel {
  userId          Int      @id @map("user_id")
  level           Int      @default(1) // 1-5级创作者
  title           String   @default("新人创作者") // 称号
  totalPlayCount  Int      @default(0) @map("total_play_count")
  totalIncome     Int      @default(0) @map("total_income")
  scriptCount     Int      @default(0) @map("script_count")
  avgRating       Float    @default(0) @map("avg_rating")
  isVerified      Boolean  @default(false) @map("is_verified") // 是否通过审核成为创作者
  verifiedAt      DateTime? @map("verified_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creator_levels")
}
