# ============================================
# AI Text Adventure 环境变量配置模板
# ============================================
# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env

# ============================================
# 后端配置
# ============================================

# 数据库连接 URL（SQLite）
# Docker 部署时使用: file:/app/data/dev.db
# 本地开发时使用:   file:./prisma/dev.db
DATABASE_URL=file:/app/data/dev.db

# JWT 配置
# 生产环境务必修改为强密码！
JWT_SECRET=change-me-in-production

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 运行环境
NODE_ENV=production

# 后端监听端口
PORT=3001

# ============================================
# 前端配置
# ============================================

# API 地址（Docker 内部通信使用 http://backend:3001/api）
# 外部访问时需要使用实际域名或 IP
NEXT_PUBLIC_API_URL=http://backend:3001/api

# ============================================
# Nginx / SSL 配置（如需 HTTPS）
# ============================================

# 域名（配置 SSL 证书时需要）
# DOMAIN=your-domain.com

# ============================================
# 可选配置
# ============================================

# 默认管理员邀请码
# DEFAULT_INVITE_CODE=

# AI 模型默认配置
# DEFAULT_AI_MODEL=gpt-3.5-turbo
# DEFAULT_AI_BASE_URL=https://api.openai.com/v1
